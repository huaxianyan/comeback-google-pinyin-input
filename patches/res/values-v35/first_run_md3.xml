<?xml version="1.0" encoding="utf-8"?>
<resources>
    <color name="first_run_md3_primary">#FF0B57D0</color>
    <color name="first_run_md3_on_primary">#FFFFFFFF</color>
    <color name="first_run_md3_primary_container">#FFD7E3FF</color>
    <color name="first_run_md3_on_primary_container">#FF001B3F</color>
    <color name="first_run_md3_surface">#FFF9F9FF</color>
    <color name="first_run_md3_surface_container">#FFEEEEF4</color>
    <color name="first_run_md3_on_surface">#FF1A1B20</color>
    <color name="first_run_md3_on_surface_variant">#FF44474F</color>
    <color name="first_run_md3_outline">#FF74777F</color>
    <color name="first_run_md3_indicator_selected">#FF0B57D0</color>
    <color name="first_run_md3_indicator_unselected">#FFB7BBC4</color>

    <dimen name="first_run_page_button_font_size">14sp</dimen>
    <dimen name="first_run_page_button_padding_top">32dp</dimen>
    <dimen name="first_run_page_content_padding">24dp</dimen>
    <dimen name="first_run_page_description_font_size">16sp</dimen>
    <dimen name="first_run_page_description_padding_top">16dp</dimen>
    <dimen name="first_run_page_footer_height">64dp</dimen>
    <dimen name="first_run_page_header_padding_top">72dp</dimen>
    <dimen name="first_run_page_navigation_text_padding">24dp</dimen>
    <dimen name="first_run_page_navigation_text_size">14sp</dimen>
    <dimen name="first_run_page_settings_done_font_size">16sp</dimen>
    <dimen name="first_run_page_settings_done_padding_top">32dp</dimen>
    <dimen name="first_run_page_title_font_size">28sp</dimen>
    <dimen name="first_run_page_title_padding_top">24dp</dimen>

    <style name="AppThemeSelector.NoTitle" parent="@android:style/Theme.Material.Light.NoActionBar">
        <item name="android:fontFamily">sans</item>
        <item name="android:windowActionModeOverlay">true</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:statusBarColor">@color/first_run_md3_surface</item>
        <item name="android:navigationBarColor">@color/first_run_md3_surface</item>
        <item name="android:windowLightNavigationBar">true</item>
        <item name="android:windowNoTitle">true</item>
    </style>

    <style name="FirstRunPage">
        <item name="android:background">@color/first_run_md3_surface</item>
        <item name="android:orientation">vertical</item>
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">match_parent</item>
    </style>
    <style name="FirstRunViewPager">
        <item name="android:background">@color/first_run_md3_surface</item>
        <item name="android:paddingBottom">@dimen/first_run_page_footer_height</item>
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">match_parent</item>
    </style>
    <style name="FirstRunPageHeader">
        <item name="android:gravity">center</item>
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
    </style>
    <style name="FirstRunPageContent">
        <item name="android:layout_gravity">center_horizontal</item>
        <item name="android:gravity">center_horizontal</item>
        <item name="android:orientation">vertical</item>
        <item name="android:paddingLeft">@dimen/first_run_page_content_padding</item>
        <item name="android:paddingRight">@dimen/first_run_page_content_padding</item>
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
    </style>
    <style name="FirstRunPageTitle">
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:textSize">@dimen/first_run_page_title_font_size</item>
        <item name="android:textColor">@color/first_run_md3_on_surface</item>
        <item name="android:gravity">center</item>
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginTop">@dimen/first_run_page_title_padding_top</item>
    </style>
    <style name="FirstRunPageDescription">
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:textSize">@dimen/first_run_page_description_font_size</item>
        <item name="android:textColor">@color/first_run_md3_on_surface_variant</item>
        <item name="android:textColorLink">@color/first_run_md3_primary</item>
        <item name="android:gravity">center</item>
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginTop">@dimen/first_run_page_description_padding_top</item>
        <item name="android:lineSpacingExtra">4dp</item>
    </style>
    <style name="FirstRunPagePermissionLabel" parent="@style/FirstRunPageDescription">
        <item name="android:enabled">false</item>
        <item name="android:textColor">@color/first_run_md3_on_surface_variant</item>
    </style>
    <style name="FirstRunPageButton">
        <item name="android:background">@drawable/bg_first_run_md3_button</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textSize">@dimen/first_run_page_button_font_size</item>
        <item name="android:textColor">@color/first_run_md3_on_primary</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:gravity">center</item>
        <item name="android:layout_gravity">center_horizontal</item>
        <item name="android:paddingLeft">24dp</item>
        <item name="android:paddingRight">24dp</item>
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">48dp</item>
        <item name="android:minWidth">120dp</item>
        <item name="android:layout_marginTop">@dimen/first_run_page_button_padding_top</item>
        <item name="android:elevation">2dp</item>
        <item name="android:stateListAnimator">@null</item>
    </style>
    <style name="FirstRunPageSettingsDone">
        <item name="android:background">@drawable/bg_first_run_md3_done_container</item>
        <item name="android:gravity">center</item>
        <item name="android:orientation">horizontal</item>
        <item name="android:paddingLeft">20dp</item>
        <item name="android:paddingRight">20dp</item>
        <item name="android:layout_gravity">center_horizontal</item>
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">48dp</item>
        <item name="android:layout_marginTop">@dimen/first_run_page_settings_done_padding_top</item>
    </style>
    <style name="FirstRunPageSettingsDoneCheck">
        <item name="android:padding">2dp</item>
        <item name="android:layout_width">24dp</item>
        <item name="android:layout_height">24dp</item>
        <item name="android:src">@drawable/ic_first_run_finished_check</item>
        <item name="android:tint">@color/first_run_md3_on_primary_container</item>
        <item name="android:scaleType">centerInside</item>
    </style>
    <style name="FirstRunPageSettingsDoneText">
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textSize">@dimen/first_run_page_settings_done_font_size</item>
        <item name="android:textColor">@color/first_run_md3_on_primary_container</item>
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginLeft">8dp</item>
        <item name="android:text">@string/first_run_setup_done_hint</item>
    </style>
    <style name="FirstRunPageFooter">
        <item name="android:layout_gravity">bottom</item>
        <item name="android:gravity">center</item>
        <item name="android:orientation">vertical</item>
        <item name="android:background">@color/first_run_md3_surface</item>
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">@dimen/first_run_page_footer_height</item>
    </style>
    <style name="FirstRunNavigation">
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textSize">@dimen/first_run_page_navigation_text_size</item>
        <item name="android:textColor">@color/first_run_md3_primary</item>
        <item name="android:gravity">center</item>
        <item name="android:background">?android:attr/selectableItemBackgroundBorderless</item>
        <item name="android:paddingLeft">@dimen/first_run_page_navigation_text_padding</item>
        <item name="android:paddingRight">@dimen/first_run_page_navigation_text_padding</item>
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">match_parent</item>
    </style>
    <style name="FirstRunNavigation.Center" parent="@style/FirstRunNavigation">
        <item name="android:layout_gravity">center</item>
    </style>
</resources>
